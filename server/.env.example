# TaskTitan-AI Server – Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit your actual .env file to version control.
# ============================================================

# ── Server Configuration ──────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
# For local development:
#   MONGODB_URI=mongodb://127.0.0.1:27017/tasktitan
#
# For MongoDB Atlas (production recommended):
#   MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/tasktitan?retryWrites=true&w=majority
#
# Replace <username>, <password>, and <cluster> with your Atlas credentials.
MONGODB_URI=MONGODB_URI=mongodb+srv://tasktitan?retryWrites=true&w=majority&appName=Cluster0

# ── Authentication ────────────────────────────────────────────
# Generate a secure secret: openssl rand -hex 64
# NEVER use a simple or default value in production.
JWT_SECRET=superninja_jwt_secret_token_2026_prod_key
JWT_EXPIRES_IN=30d

# ── Gemini AI (Google) ────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# Leave empty to use heuristic fallbacks (no AI-powered features).
GEMINI_API_KEY=AQ.Ab8RN6JO0A1ltN106_ZB1ccITE2APl6jLtdkdvozjivjds

# ── Rate Limiting ─────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS: Time window in milliseconds (default: 15 minutes)
# RATE_LIMIT_MAX: Max requests per IP per window (default: 200)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# For production, set to your actual deployed frontend URL.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
